@page "/history"
@using DbTraffic.Core.Entities
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>Historial - DbTraffic</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-6">
    <MudText Typo="Typo.h4" Class="mb-4">Historial de ejecuciones</MudText>

    @if (_executions == null || _instances == null || _processes == null)
    {
        <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
    }
    else
    {
        <MudGrid>
            <MudItem xs="12" lg="8">
                <MudCard Elevation="2">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">Ejecuciones</MudText>
                        </CardHeaderContent>
                        <CardHeaderActions>
                            <MudSelect T="Guid" Value="_selectedInstanceId" ValueChanged="OnInstanceFilterChanged" Label="Instancia" Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true" Style="width: 220px;">
                                <MudSelectItem T="Guid" Value="Guid.Empty">Todas las instancias</MudSelectItem>
                                @foreach (var instance in _instances)
                                {
                                    <MudSelectItem T="Guid" Value="instance.Id">@instance.Name</MudSelectItem>
                                }
                            </MudSelect>
                        </CardHeaderActions>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudTable Items="_executions" Hover="true" Striped="true" Bordered="true" Breakpoint="Breakpoint.Sm" Dense="true">
                            <HeaderContent>
                                <MudTh>Inicio</MudTh>
                                <MudTh>Instancia</MudTh>
                                <MudTh>Proceso</MudTh>
                                <MudTh>Origen</MudTh>
                                <MudTh>Duración</MudTh>
                                <MudTh>Estado</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="Inicio">@context.StartedAt.ToString("g")</MudTd>
                                <MudTd DataLabel="Instancia">@GetInstanceName(context.InstanceId)</MudTd>
                                <MudTd DataLabel="Proceso">@GetProcessName(context.ProcessId)</MudTd>
                                <MudTd DataLabel="Origen">@context.Source</MudTd>
                                <MudTd DataLabel="Duración">@(context.DurationMinutes.HasValue ? $"{context.DurationMinutes} min" : "-")</MudTd>
                                <MudTd DataLabel="Estado"><MudChip T="string" Size="Size.Small" Color="GetStatusColor(context.Status)">@context.Status</MudChip></MudTd>
                            </RowTemplate>
                            <NoRecordsContent>
                                <MudText Typo="Typo.body2">No hay ejecuciones registradas.</MudText>
                            </NoRecordsContent>
                        </MudTable>
                    </MudCardContent>
                </MudCard>
            </MudItem>

            <MudItem xs="12" lg="4">
                <MudCard Elevation="2" Class="mb-4">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">Registrar ejecución manual</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudSelect @bind-Value="_newExecution.InstanceId" Label="Instancia" Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true" Required="true">
                            <MudSelectItem Value="Guid.Empty">Seleccione...</MudSelectItem>
                            @foreach (var instance in _instances)
                            {
                                <MudSelectItem Value="instance.Id">@instance.Name</MudSelectItem>
                            }
                        </MudSelect>
                        <MudSelect @bind-Value="_newExecution.ProcessId" Label="Proceso" Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true" Class="mt-3">
                            <MudSelectItem Value="(Guid?)null">Ninguno</MudSelectItem>
                            @foreach (var process in _processes)
                            {
                                <MudSelectItem Value="(Guid?)process.Id">@process.Name</MudSelectItem>
                            }
                        </MudSelect>
                        <MudDatePicker @bind-Date="_newExecutionStartedDate" Label="Fecha de inicio" Variant="Variant.Outlined" Margin="Margin.Dense" Class="mt-3" />
                        <MudTimePicker @bind-Time="_newExecutionStartedTime" Label="Hora de inicio" Variant="Variant.Outlined" Margin="Margin.Dense" Class="mt-3" />
                        <MudDatePicker @bind-Date="_newExecutionCompletedDate" Label="Fecha de fin" Variant="Variant.Outlined" Margin="Margin.Dense" Class="mt-3" />
                        <MudTimePicker @bind-Time="_newExecutionCompletedTime" Label="Hora de fin" Variant="Variant.Outlined" Margin="Margin.Dense" Class="mt-3" />
                        <MudSelect @bind-Value="_newExecution.Status" Label="Estado" Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true" Class="mt-3">
                            <MudSelectItem Value="@("Completed")">Completado</MudSelectItem>
                            <MudSelectItem Value="@("Failed")">Fallido</MudSelectItem>
                            <MudSelectItem Value="@("Cancelled")">Cancelado</MudSelectItem>
                            <MudSelectItem Value="@("Running")">En ejecución</MudSelectItem>
                        </MudSelect>
                        <MudTextField @bind-Value="_newExecution.Notes" Label="Notas" Variant="Variant.Outlined" Margin="Margin.Dense" Lines="2" Class="mt-3" />
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="CreateExecutionAsync">Registrar</MudButton>
                    </MudCardActions>
                </MudCard>

                <MudCard Elevation="2" Class="mb-4">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">Importar desde SQL Agent</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudSelect @bind-Value="_importInstanceId" Label="Instancia" Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true">
                            <MudSelectItem Value="Guid.Empty">Seleccione...</MudSelectItem>
                            @foreach (var instance in _instances)
                            {
                                <MudSelectItem Value="instance.Id">@instance.Name</MudSelectItem>
                            }
                        </MudSelect>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="ImportHistoryAsync" Disabled="@(_importInstanceId == Guid.Empty)">Importar últimos 30 días</MudButton>
                    </MudCardActions>
                </MudCard>

                <MudCard Elevation="2">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">Calibrar duración</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudSelect @bind-Value="_calibrateProcessId" Label="Proceso" Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true">
                            <MudSelectItem Value="Guid.Empty">Seleccione...</MudSelectItem>
                            @foreach (var process in _processes)
                            {
                                <MudSelectItem Value="process.Id">@process.Name</MudSelectItem>
                            }
                        </MudSelect>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Variant="Variant.Outlined" Color="Color.Tertiary" OnClick="CalibrateAsync" Disabled="@(_calibrateProcessId == Guid.Empty)">Calibrar duración estimada</MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>
        </MudGrid>
    }
</MudContainer>

@code {
    private List<Execution>? _executions;
    private List<Instance>? _instances;
    private List<Process>? _processes;
    private Guid _selectedInstanceId;
    private Guid _importInstanceId;
    private Guid _calibrateProcessId;
    private Execution _newExecution = new();
    private DateTime? _newExecutionStartedDate;
    private TimeSpan? _newExecutionStartedTime;
    private DateTime? _newExecutionCompletedDate;
    private TimeSpan? _newExecutionCompletedTime;

    protected override async Task OnInitializedAsync()
    {
        var client = CreateClient();
        _instances = await client.GetFromJsonAsync<List<Instance>>("api/instances");
        _processes = await client.GetFromJsonAsync<List<Process>>("api/processes");
        await LoadExecutionsAsync();
    }

    private async Task OnInstanceFilterChanged(Guid instanceId)
    {
        _selectedInstanceId = instanceId;
        await LoadExecutionsAsync();
    }

    private async Task LoadExecutionsAsync()
    {
        var client = CreateClient();
        var url = _selectedInstanceId == Guid.Empty
            ? "api/executions"
            : $"api/executions?instanceId={_selectedInstanceId}";

        _executions = await client.GetFromJsonAsync<List<Execution>>(url);
    }

    private async Task CreateExecutionAsync()
    {
        if (_newExecution.InstanceId == Guid.Empty) return;

        _newExecution.StartedAt = CombineDateTime(_newExecutionStartedDate, _newExecutionStartedTime) ?? DateTime.Now;
        _newExecution.CompletedAt = CombineDateTime(_newExecutionCompletedDate, _newExecutionCompletedTime);

        _newExecution.Source = "Manual";
        if (_newExecution.CompletedAt.HasValue && _newExecution.StartedAt != default)
        {
            _newExecution.DurationMinutes = (int?)((_newExecution.CompletedAt.Value - _newExecution.StartedAt).TotalMinutes);
        }

        var client = CreateClient();
        var response = await client.PostAsJsonAsync("api/executions", _newExecution);
        if (response.IsSuccessStatusCode)
        {
            _newExecution = new Execution();
            _newExecutionStartedDate = null;
            _newExecutionStartedTime = null;
            _newExecutionCompletedDate = null;
            _newExecutionCompletedTime = null;
            await LoadExecutionsAsync();
            Snackbar.Add("Ejecución registrada", Severity.Success);
        }
        else
        {
            Snackbar.Add("Error al registrar ejecución", Severity.Error);
        }
    }

    private async Task ImportHistoryAsync()
    {
        if (_importInstanceId == Guid.Empty) return;

        var client = CreateClient();
        var response = await client.PostAsync($"api/executions/import/{_importInstanceId}", null);
        if (response.IsSuccessStatusCode)
        {
            await LoadExecutionsAsync();
            Snackbar.Add("Historial importado", Severity.Success);
        }
        else
        {
            Snackbar.Add("Error al importar historial", Severity.Error);
        }
    }

    private async Task CalibrateAsync()
    {
        if (_calibrateProcessId == Guid.Empty) return;

        var client = CreateClient();
        var response = await client.PostAsync($"api/executions/processes/{_calibrateProcessId}/calibrate", null);
        if (response.IsSuccessStatusCode)
        {
            Snackbar.Add("Duración calibrada", Severity.Success);
        }
        else
        {
            Snackbar.Add("Error al calibrar duración", Severity.Error);
        }
    }

    private DateTime? CombineDateTime(DateTime? date, TimeSpan? time)
    {
        if (!date.HasValue) return null;
        return date.Value.Date + (time ?? TimeSpan.Zero);
    }

    private string GetInstanceName(Guid instanceId)
    {
        return _instances?.FirstOrDefault(i => i.Id == instanceId)?.Name ?? "Desconocida";
    }

    private string GetProcessName(Guid? processId)
    {
        return processId.HasValue
            ? _processes?.FirstOrDefault(p => p.Id == processId.Value)?.Name ?? "Desconocido"
            : "-";
    }

    private static Color GetStatusColor(string status) => status switch
    {
        "Completed" => Color.Success,
        "Failed" => Color.Error,
        "Cancelled" => Color.Warning,
        "Running" => Color.Primary,
        _ => Color.Default
    };

    private HttpClient CreateClient()
    {
        var client = HttpClientFactory.CreateClient();
        client.BaseAddress = new Uri(Navigation.BaseUri);
        return client;
    }
}
