@page "/processes"
@using DbTraffic.Core.Entities
@using DbTraffic.Core.Enums
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>Procesos - DbTraffic</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-6">
    <MudText Typo="Typo.h4" Class="mb-4">Procesos</MudText>

    @if (_processes == null || _instances == null)
    {
        <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
    }
    else
    {
        <MudGrid>
            <MudItem xs="12" lg="8">
                <MudTable Items="_processes" Hover="true" Striped="true" Bordered="true" Elevation="2" Breakpoint="Breakpoint.Sm">
                    <HeaderContent>
                        <MudTh>Nombre</MudTh>
                        <MudTh>Tipo</MudTh>
                        <MudTh>Instancia</MudTh>
                        <MudTh>Duración</MudTh>
                        <MudTh>Intensidad</MudTh>
                        <MudTh Style="text-align: right;">Acciones</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Nombre">@context.Name</MudTd>
                        <MudTd DataLabel="Tipo">@context.ProcessType</MudTd>
                        <MudTd DataLabel="Instancia">@GetInstanceName(context.InstanceId)</MudTd>
                        <MudTd DataLabel="Duración">@context.EstimatedDurationMinutes min</MudTd>
                        <MudTd DataLabel="Intensidad">
                            <MudChip T="string" Size="Size.Small" Color="Color.Info">CPU @context.CpuIntensity</MudChip>
                            <MudChip T="string" Size="Size.Small" Color="Color.Warning">IO @context.IoIntensity</MudChip>
                        </MudTd>
                        <MudTd Style="text-align: right;">
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="() => DeleteProcess(context.Id)" aria-label="Eliminar proceso" />
                        </MudTd>
                    </RowTemplate>
                    <NoRecordsContent>
                        <MudText Typo="Typo.body2">No hay procesos registrados.</MudText>
                    </NoRecordsContent>
                </MudTable>
            </MudItem>

            <MudItem xs="12" lg="4">
                <MudCard Elevation="2">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">Nuevo proceso</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudTextField @bind-Value="_newProcess.Name" Label="Nombre" Variant="Variant.Outlined" Margin="Margin.Dense" Required="true" />
                        <MudSelect @bind-Value="_newProcess.InstanceId" Label="Instancia" Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true" Class="mt-3" Required="true">
                            <MudSelectItem Value="Guid.Empty">Seleccione...</MudSelectItem>
                            @foreach (var instance in _instances)
                            {
                                <MudSelectItem Value="instance.Id">@instance.Name</MudSelectItem>
                            }
                        </MudSelect>
                        <MudSelect @bind-Value="_newProcess.ProcessType" Label="Tipo" Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true" Class="mt-3">
                            @foreach (var type in Enum.GetValues<ProcessType>())
                            {
                                <MudSelectItem Value="type">@type</MudSelectItem>
                            }
                        </MudSelect>
                        <MudNumericField @bind-Value="_newProcess.EstimatedDurationMinutes" Label="Duración estimada (min)" Variant="Variant.Outlined" Margin="Margin.Dense" Min="1" Class="mt-3" />
                        <MudSelect @bind-Value="_newProcess.CpuIntensity" Label="Intensidad CPU" Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true" Class="mt-3">
                            @foreach (var level in Enum.GetValues<IntensityLevel>())
                            {
                                <MudSelectItem Value="level">@level</MudSelectItem>
                            }
                        </MudSelect>
                        <MudSelect @bind-Value="_newProcess.IoIntensity" Label="Intensidad IO" Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true" Class="mt-3">
                            @foreach (var level in Enum.GetValues<IntensityLevel>())
                            {
                                <MudSelectItem Value="level">@level</MudSelectItem>
                            }
                        </MudSelect>
                        <MudSelect @bind-Value="_newProcess.MemoryIntensity" Label="Intensidad Memoria" Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true" Class="mt-3">
                            @foreach (var level in Enum.GetValues<IntensityLevel>())
                            {
                                <MudSelectItem Value="level">@level</MudSelectItem>
                            }
                        </MudSelect>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="CreateProcess">Crear</MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>
        </MudGrid>
    }
</MudContainer>

@code {
    private List<Process>? _processes;
    private List<Instance>? _instances;
    private Process _newProcess = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        var client = CreateClient();
        _instances = await client.GetFromJsonAsync<List<Instance>>("api/instances");
        _processes = await client.GetFromJsonAsync<List<Process>>("api/processes");
    }

    private string GetInstanceName(Guid instanceId)
    {
        return _instances?.FirstOrDefault(i => i.Id == instanceId)?.Name ?? "Desconocida";
    }

    private async Task CreateProcess()
    {
        var client = CreateClient();
        var response = await client.PostAsJsonAsync("api/processes", _newProcess);
        if (response.IsSuccessStatusCode)
        {
            _newProcess = new Process();
            await LoadDataAsync();
            Snackbar.Add("Proceso creado", Severity.Success);
        }
        else
        {
            Snackbar.Add($"Error al crear proceso: {response.StatusCode}", Severity.Error);
        }
    }

    private async Task DeleteProcess(Guid id)
    {
        var client = CreateClient();
        var response = await client.DeleteAsync($"api/processes/{id}");
        if (response.IsSuccessStatusCode)
        {
            await LoadDataAsync();
            Snackbar.Add("Proceso eliminado", Severity.Success);
        }
        else
        {
            Snackbar.Add($"Error al eliminar proceso: {response.StatusCode}", Severity.Error);
        }
    }

    private HttpClient CreateClient()
    {
        var client = HttpClientFactory.CreateClient();
        client.BaseAddress = new Uri(Navigation.BaseUri);
        return client;
    }
}
