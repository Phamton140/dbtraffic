@page "/risk"
@using DbTraffic.Core.Entities
@using DbTraffic.Core.Rules
@using DbTraffic.Core.Services
@inject IHttpClientFactory HttpClientFactory

@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>Análisis de riesgo - DbTraffic</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-6">
    <MudText Typo="Typo.h4" Class="mb-4">Análisis de riesgo</MudText>

    @if (_processes == null)
    {
        <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
    }
    else
    {
        <MudGrid>
            <MudItem xs="12" lg="4">
                <MudCard Elevation="2">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">Simular ejecución</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudSelect @bind-Value="_selectedProcessId" Label="Proceso" Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true" Required="true">
                            <MudSelectItem Value="Guid.Empty">Seleccione...</MudSelectItem>
                            @foreach (var process in _processes)
                            {
                                <MudSelectItem Value="process.Id">@process.Name</MudSelectItem>
                            }
                        </MudSelect>
                        <MudDatePicker @bind-Date="_proposedDate" Label="Fecha propuesta" Variant="Variant.Outlined" Margin="Margin.Dense" Class="mt-4" />
                        <MudTimePicker @bind-Time="_proposedTime" Label="Hora propuesta" Variant="Variant.Outlined" Margin="Margin.Dense" Class="mt-4" />
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="AnalyzeRisk" Disabled="@(_selectedProcessId == Guid.Empty)" StartIcon="@Icons.Material.Filled.Analytics">Analizar riesgo</MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>

            <MudItem xs="12" lg="8">
                @if (_assessment != null)
                {
                    <MudCard Elevation="2">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.h6">Resultado del análisis</MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudGrid>
                                <MudItem xs="12" md="5" Class="d-flex flex-column align-center justify-center">
                                    <MudProgressCircular Size="Size.Large" Value="GetGaugeValue()" Max="100" Color="GetRiskColor(_assessment.OverallLevel)" Style="width: 180px; height: 180px;" />
                                    <MudText Typo="Typo.h3" Class="mt-4">@_assessment.TotalScore.ToString("F0")</MudText>
                                    <MudChip T="string" Size="Size.Large" Color="GetRiskColor(_assessment.OverallLevel)" Class="mt-2">@_assessment.OverallLevel</MudChip>
                                </MudItem>
                                <MudItem xs="12" md="7">
                                    <MudText Typo="Typo.h6" Class="mb-3">Hallazgos</MudText>
                                    @if (_assessment.Findings.All(f => f.Level == RiskLevel.None))
                                    {
                                        <MudAlert Severity="Severity.Success" Dense="true">No se detectaron riesgos.</MudAlert>
                                    }
                                    else
                                    {
                                        <MudList T="RuleResult" Dense="true">
                                            @foreach (var finding in _assessment.Findings.Where(f => f.Level != RiskLevel.None))
                                            {
                                                <MudListItem T="RuleResult">
                                                    <div class="d-flex align-center justify-space-between">
                                                        <MudText Typo="Typo.subtitle2">@finding.RuleName</MudText>
                                                        <MudChip T="string" Size="Size.Small" Color="GetRiskColor(finding.Level)">@finding.Level</MudChip>
                                                    </div>
                                                    <MudText Typo="Typo.body2">@finding.Message</MudText>
                                                    <MudText Typo="Typo.caption">Score: @finding.Score.ToString("F1")</MudText>
                                                </MudListItem>
                                                <MudDivider />
                                            }
                                        </MudList>
                                    }
                                </MudItem>
                            </MudGrid>
                        </MudCardContent>
                    </MudCard>
                }
                else
                {
                    <MudCard Elevation="0" Class="pa-6 d-flex flex-column align-center justify-center" Style="background-color: #FFFFFF; min-height: 300px;">
                        <MudIcon Icon="@Icons.Material.Filled.Analytics" Color="Color.Primary" Size="Size.Large" Class="mb-4" />
                        <MudText Typo="Typo.h6" Align="Align.Center">Selecciona un proceso y una fecha/hora para analizar el riesgo.</MudText>
                    </MudCard>
                }
            </MudItem>
        </MudGrid>
    }
</MudContainer>

@code {
    private List<Process>? _processes;
    private Guid _selectedProcessId;
    private DateTime _proposedStartTime = DateTime.Now;
    private DateTime? _proposedDate = DateTime.Now.Date;
    private TimeSpan? _proposedTime = DateTime.Now.TimeOfDay;
    private RiskAssessment? _assessment;

    protected override async Task OnInitializedAsync()
    {
        var client = CreateClient();
        _processes = await client.GetFromJsonAsync<List<Process>>("api/processes");
    }

    private async Task AnalyzeRisk()
    {
        if (_selectedProcessId == Guid.Empty) return;

        var proposed = CombineDateTime(_proposedDate, _proposedTime) ?? DateTime.Now;
        _proposedStartTime = proposed;

        var client = CreateClient();
        var response = await client.GetAsync($"api/risk?processId={_selectedProcessId}&proposedStartTime={Uri.EscapeDataString(proposed.ToString("O"))}");
        if (response.IsSuccessStatusCode)
        {
            _assessment = await response.Content.ReadFromJsonAsync<RiskAssessment>();
        }
        else
        {
            Snackbar.Add("Error al analizar riesgo", Severity.Error);
        }
    }

    private DateTime? CombineDateTime(DateTime? date, TimeSpan? time)
    {
        if (!date.HasValue) return null;
        return date.Value.Date + (time ?? TimeSpan.Zero);
    }

    private int GetGaugeValue()
    {
        if (_assessment == null) return 0;
        var value = (int)_assessment.TotalScore;
        return value > 100 ? 100 : value;
    }

    private static Color GetRiskColor(RiskLevel level) => level switch
    {
        RiskLevel.None => Color.Success,
        RiskLevel.Low => Color.Info,
        RiskLevel.Medium => Color.Warning,
        RiskLevel.High => Color.Error,
        RiskLevel.Critical => Color.Dark,
        _ => Color.Default
    };

    private HttpClient CreateClient()
    {
        var client = HttpClientFactory.CreateClient();
        client.BaseAddress = new Uri(Navigation.BaseUri);
        return client;
    }
}
