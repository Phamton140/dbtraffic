@page "/history"
@using DbTraffic.Core.Entities
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Navigation

<PageTitle>Historial - DbTraffic</PageTitle>

<h1>Historial de ejecuciones</h1>

@if (_executions == null || _instances == null || _processes == null)
{
    <p><em>Cargando...</em></p>
}
else
{
    <div class="row">
        <div class="col-md-8">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h3>Ejecuciones</h3>
                <div>
                    <select class="form-select form-select-sm d-inline-block w-auto me-2" @bind="_selectedInstanceId" @bind:after="LoadExecutionsAsync">
                        <option value="">Todas las instancias</option>
                        @foreach (var instance in _instances)
                        {
                            <option value="@instance.Id">@instance.Name</option>
                        }
                    </select>
                </div>
            </div>

            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Inicio</th>
                        <th>Instancia</th>
                        <th>Proceso</th>
                        <th>Origen</th>
                        <th>Duración</th>
                        <th>Estado</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var execution in _executions)
                    {
                        <tr>
                            <td>@execution.StartedAt.ToString("g")</td>
                            <td>@GetInstanceName(execution.InstanceId)</td>
                            <td>@GetProcessName(execution.ProcessId)</td>
                            <td>@execution.Source</td>
                            <td>@(execution.DurationMinutes.HasValue ? $"{execution.DurationMinutes} min" : "-")</td>
                            <td><span class="badge @GetStatusBadgeClass(execution.Status)">@execution.Status</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="col-md-4">
            <div class="card mb-3">
                <div class="card-header">Registrar ejecución manual</div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label">Instancia</label>
                        <select class="form-select" @bind="_newExecution.InstanceId">
                            <option value="">Seleccione...</option>
                            @foreach (var instance in _instances)
                            {
                                <option value="@instance.Id">@instance.Name</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Proceso</label>
                        <select class="form-select" @bind="_newExecution.ProcessId">
                            <option value="">Ninguno</option>
                            @foreach (var process in _processes)
                            {
                                <option value="@process.Id">@process.Name</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Inicio</label>
                        <input type="datetime-local" class="form-control" @bind="_newExecution.StartedAt" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Fin</label>
                        <input type="datetime-local" class="form-control" @bind="_newExecution.CompletedAt" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Estado</label>
                        <select class="form-select" @bind="_newExecution.Status">
                            <option value="Completed">Completado</option>
                            <option value="Failed">Fallido</option>
                            <option value="Cancelled">Cancelado</option>
                            <option value="Running">En ejecución</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Notas</label>
                        <textarea class="form-control" @bind="_newExecution.Notes"></textarea>
                    </div>
                    <button class="btn btn-primary" @onclick="CreateExecutionAsync">Registrar</button>
                </div>
            </div>

            <div class="card mb-3">
                <div class="card-header">Importar desde SQL Agent</div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label">Instancia</label>
                        <select class="form-select" @bind="_importInstanceId">
                            <option value="">Seleccione...</option>
                            @foreach (var instance in _instances)
                            {
                                <option value="@instance.Id">@instance.Name</option>
                            }
                        </select>
                    </div>
                    <button class="btn btn-secondary" @onclick="ImportHistoryAsync" disabled="@(_importInstanceId == Guid.Empty)">Importar últimos 30 días</button>
                </div>
            </div>

            <div class="card">
                <div class="card-header">Calibrar duración</div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label">Proceso</label>
                        <select class="form-select" @bind="_calibrateProcessId">
                            <option value="">Seleccione...</option>
                            @foreach (var process in _processes)
                            {
                                <option value="@process.Id">@process.Name</option>
                            }
                        </select>
                    </div>
                    <button class="btn btn-secondary" @onclick="CalibrateAsync" disabled="@(_calibrateProcessId == Guid.Empty)">Calibrar duración estimada</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<Execution>? _executions;
    private List<Instance>? _instances;
    private List<Process>? _processes;
    private Guid _selectedInstanceId;
    private Guid _importInstanceId;
    private Guid _calibrateProcessId;
    private Execution _newExecution = new();

    protected override async Task OnInitializedAsync()
    {
        var client = CreateClient();
        _instances = await client.GetFromJsonAsync<List<Instance>>("api/instances");
        _processes = await client.GetFromJsonAsync<List<Process>>("api/processes");
        await LoadExecutionsAsync();
    }

    private async Task LoadExecutionsAsync()
    {
        var client = CreateClient();
        var url = _selectedInstanceId == Guid.Empty
            ? "api/executions"
            : $"api/executions?instanceId={_selectedInstanceId}";

        _executions = await client.GetFromJsonAsync<List<Execution>>(url);
    }

    private async Task CreateExecutionAsync()
    {
        if (_newExecution.InstanceId == Guid.Empty) return;

        _newExecution.Source = "Manual";
        if (_newExecution.CompletedAt.HasValue && _newExecution.StartedAt != default)
        {
            _newExecution.DurationMinutes = (int?)((_newExecution.CompletedAt.Value - _newExecution.StartedAt).TotalMinutes);
        }

        var client = CreateClient();
        var response = await client.PostAsJsonAsync("api/executions", _newExecution);
        if (response.IsSuccessStatusCode)
        {
            _newExecution = new Execution();
            await LoadExecutionsAsync();
        }
    }

    private async Task ImportHistoryAsync()
    {
        if (_importInstanceId == Guid.Empty) return;

        var client = CreateClient();
        await client.PostAsync($"api/executions/import/{_importInstanceId}", null);
        await LoadExecutionsAsync();
    }

    private async Task CalibrateAsync()
    {
        if (_calibrateProcessId == Guid.Empty) return;

        var client = CreateClient();
        await client.PostAsync($"api/executions/processes/{_calibrateProcessId}/calibrate", null);
    }

    private string GetInstanceName(Guid instanceId)
    {
        return _instances?.FirstOrDefault(i => i.Id == instanceId)?.Name ?? "Desconocida";
    }

    private string GetProcessName(Guid? processId)
    {
        return processId.HasValue
            ? _processes?.FirstOrDefault(p => p.Id == processId.Value)?.Name ?? "Desconocido"
            : "-";
    }

    private static string GetStatusBadgeClass(string status) => status switch
    {
        "Completed" => "bg-success",
        "Failed" => "bg-danger",
        "Cancelled" => "bg-warning",
        "Running" => "bg-primary",
        _ => "bg-secondary"
    };

    private HttpClient CreateClient()
    {
        var client = HttpClientFactory.CreateClient();
        client.BaseAddress = new Uri(Navigation.BaseUri);
        return client;
    }
}
