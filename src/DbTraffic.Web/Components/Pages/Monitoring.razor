@page "/monitoring"
@using DbTraffic.Core.Entities
@using DbTraffic.Shared.Models.Dmv
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>Monitoreo - DbTraffic</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-6">
    <MudText Typo="Typo.h4" Class="mb-4">Monitoreo de instancias</MudText>

    @if (_instances == null)
    {
        <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
    }
    else
    {
        <MudCard Elevation="2" Class="mb-4">
            <MudCardContent>
                <MudGrid>
                    <MudItem xs="12" md="6">
                        <MudSelect @bind-Value="_selectedInstanceId" Label="Instancia" Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true">
                            <MudSelectItem Value="Guid.Empty">Seleccione...</MudSelectItem>
                            @foreach (var instance in _instances)
                            {
                                <MudSelectItem Value="instance.Id">@instance.Name</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="6" Class="d-flex align-center">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="RefreshMetricsAsync" Disabled="@(_selectedInstanceId == Guid.Empty)" StartIcon="@Icons.Material.Filled.Refresh">Actualizar</MudButton>
                        <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="CaptureSnapshotAsync" Disabled="@(_selectedInstanceId == Guid.Empty)" Class="ml-2" StartIcon="@Icons.Material.Filled.Camera">Capturar snapshot</MudButton>
                    </MudItem>
                </MudGrid>
            </MudCardContent>
        </MudCard>

        @if (_metrics != null)
        {
            <MudGrid Class="mb-4">
                <MudItem xs="12" sm="6" md="3">
                    <MudCard Elevation="2" Style="height: 100%;">
                        <MudCardContent Class="d-flex flex-column align-center">
                            <MudText Typo="Typo.subtitle2">CPU</MudText>
                            <MudText Typo="Typo.h4" Color="Color.Primary">@_metrics.CpuPercent.ToString("F1")%</MudText>
                            <MudProgressLinear Value="@GetClampedValue(_metrics.CpuPercent)" Max="100" Color="Color.Primary" Class="mt-2" />
                        </MudCardContent>
                    </MudCard>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudCard Elevation="2" Style="height: 100%;">
                        <MudCardContent Class="d-flex flex-column align-center">
                            <MudText Typo="Typo.subtitle2">Memoria</MudText>
                            <MudText Typo="Typo.h4" Color="Color.Secondary">@_metrics.MemoryPercent.ToString("F1")%</MudText>
                            <MudProgressLinear Value="@GetClampedValue(_metrics.MemoryPercent)" Max="100" Color="Color.Secondary" Class="mt-2" />
                        </MudCardContent>
                    </MudCard>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudCard Elevation="2" Style="height: 100%;">
                        <MudCardContent Class="d-flex flex-column align-center">
                            <MudText Typo="Typo.subtitle2">Requests activos</MudText>
                            <MudText Typo="Typo.h4" Color="Color.Success">@_metrics.ActiveRequests</MudText>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudCard Elevation="2" Style="height: 100%;">
                        <MudCardContent Class="d-flex flex-column align-center">
                            <MudText Typo="Typo.subtitle2">Bloqueos</MudText>
                            <MudText Typo="Typo.h4" Color="Color.Error">@_metrics.BlockingSessions</MudText>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            </MudGrid>

            <MudCard Elevation="2">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">Requests activos</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    @if (_metrics.ActiveRequestsDetail.Count == 0)
                    {
                        <MudText Typo="Typo.body2">No hay requests activos.</MudText>
                    }
                    else
                    {
                        <MudTable Items="_metrics.ActiveRequestsDetail" Hover="true" Striped="true" Bordered="true" Breakpoint="Breakpoint.Sm" Dense="true">
                            <HeaderContent>
                                <MudTh>Session</MudTh>
                                <MudTh>Status</MudTh>
                                <MudTh>Command</MudTh>
                                <MudTh>Database</MudTh>
                                <MudTh>Login</MudTh>
                                <MudTh>Program</MudTh>
                                <MudTh>Start</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="Session">@context.SessionId</MudTd>
                                <MudTd DataLabel="Status">@context.Status</MudTd>
                                <MudTd DataLabel="Command">@context.Command</MudTd>
                                <MudTd DataLabel="Database">@context.DatabaseName</MudTd>
                                <MudTd DataLabel="Login">@context.LoginName</MudTd>
                                <MudTd DataLabel="Program">@context.ProgramName</MudTd>
                                <MudTd DataLabel="Start">@context.StartTime?.ToString("g")</MudTd>
                            </RowTemplate>
                        </MudTable>
                    }
                </MudCardContent>
            </MudCard>
        }
    }
</MudContainer>

@code {
    private List<Instance>? _instances;
    private Guid _selectedInstanceId;
    private InstanceMetrics? _metrics;

    protected override async Task OnInitializedAsync()
    {
        var client = CreateClient();
        _instances = await client.GetFromJsonAsync<List<Instance>>("api/instances");
    }

    private async Task RefreshMetricsAsync()
    {
        if (_selectedInstanceId == Guid.Empty)
        {
            _metrics = null;
            return;
        }

        var client = CreateClient();
        _metrics = await client.GetFromJsonAsync<InstanceMetrics>($"api/monitoring/instances/{_selectedInstanceId}/metrics");
    }

    private async Task CaptureSnapshotAsync()
    {
        if (_selectedInstanceId == Guid.Empty) return;

        var client = CreateClient();
        var response = await client.PostAsync($"api/monitoring/instances/{_selectedInstanceId}/snapshot", null);
        if (response.IsSuccessStatusCode)
        {
            await RefreshMetricsAsync();
            Snackbar.Add("Snapshot capturado", Severity.Success);
        }
        else
        {
            Snackbar.Add("Error al capturar snapshot", Severity.Error);
        }
    }

    private static int GetClampedValue(double value)
    {
        if (value < 0) return 0;
        if (value > 100) return 100;
        return (int)value;
    }

    private HttpClient CreateClient()
    {
        var client = HttpClientFactory.CreateClient();
        client.BaseAddress = new Uri(Navigation.BaseUri);
        return client;
    }
}
