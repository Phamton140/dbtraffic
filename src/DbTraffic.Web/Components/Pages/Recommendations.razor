@page "/recommendations"
@using DbTraffic.Core.Entities
@using DbTraffic.Core.Rules
@using DbTraffic.Core.Services
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>Recomendaciones - DbTraffic</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-6">
    <MudText Typo="Typo.h4" Class="mb-4">Recomendaciones de ejecución</MudText>

    @if (_processes == null)
    {
        <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
    }
    else
    {
        <MudGrid>
            <MudItem xs="12" lg="4">
                <MudCard Elevation="2">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">Buscar ventanas</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudSelect @bind-Value="_selectedProcessId" Label="Proceso" Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true" Required="true">
                            <MudSelectItem Value="Guid.Empty">Seleccione...</MudSelectItem>
                            @foreach (var process in _processes)
                            {
                                <MudSelectItem Value="process.Id">@process.Name</MudSelectItem>
                            }
                        </MudSelect>
                        <MudDatePicker @bind-Date="_searchStartDate" Label="Inicio de búsqueda" Variant="Variant.Outlined" Margin="Margin.Dense" Class="mt-4" />
                        <MudDatePicker @bind-Date="_searchEndDate" Label="Fin de búsqueda" Variant="Variant.Outlined" Margin="Margin.Dense" Class="mt-4" />
                        <MudNumericField @bind-Value="_granularityMinutes" Label="Granularidad (min)" Variant="Variant.Outlined" Margin="Margin.Dense" Min="5" Class="mt-4" />
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="FindRecommendations" Disabled="@(_selectedProcessId == Guid.Empty)" StartIcon="@Icons.Material.Filled.Search">Buscar recomendaciones</MudButton>
                        <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="SimulateNow" Disabled="@(_selectedProcessId == Guid.Empty)" Class="ml-2">Simular "ahora"</MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>

            <MudItem xs="12" lg="8">
                @if (_nowAssessment != null)
                {
                    <MudAlert Severity="GetAlertSeverity(_nowAssessment.OverallLevel)" Class="mb-4" Dense="true">
                        <MudText Typo="Typo.subtitle1">Simulación: ejecutar ahora</MudText>
                        <MudText Typo="Typo.body2">Nivel: <strong>@_nowAssessment.OverallLevel</strong> · Score: <strong>@_nowAssessment.TotalScore.ToString("F1")</strong></MudText>
                    </MudAlert>
                }

                @if (_recommendations != null)
                {
                    <MudCard Elevation="2">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.h6">Ventanas recomendadas</MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            @if (_recommendations.Count == 0)
                            {
                                <MudText Typo="Typo.body2">No se encontraron ventanas de bajo riesgo en el rango seleccionado.</MudText>
                            }
                            else
                            {
                                <MudTable Items="_recommendations" Hover="true" Striped="true" Bordered="true" Breakpoint="Breakpoint.Sm">
                                    <HeaderContent>
                                        <MudTh>Inicio</MudTh>
                                        <MudTh>Fin</MudTh>
                                        <MudTh>Nivel</MudTh>
                                        <MudTh>Score</MudTh>
                                    </HeaderContent>
                                    <RowTemplate>
                                        <MudTd DataLabel="Inicio">@context.StartTime.ToString("g")</MudTd>
                                        <MudTd DataLabel="Fin">@context.EndTime.ToString("g")</MudTd>
                                        <MudTd DataLabel="Nivel"><MudChip T="string" Size="Size.Small" Color="GetRiskColor(context.RiskLevel)">@context.RiskLevel</MudChip></MudTd>
                                        <MudTd DataLabel="Score">@context.RiskScore.ToString("F1")</MudTd>
                                    </RowTemplate>
                                </MudTable>
                            }
                        </MudCardContent>
                    </MudCard>
                }
                else
                {
                    <MudCard Elevation="0" Class="pa-6 d-flex flex-column align-center justify-center" Style="background-color: #FFFFFF; min-height: 200px;">
                        <MudIcon Icon="@Icons.Material.Filled.CalendarMonth" Color="Color.Primary" Size="Size.Large" Class="mb-4" />
                        <MudText Typo="Typo.h6" Align="Align.Center">Define un rango de búsqueda para encontrar las mejores ventanas de ejecución.</MudText>
                    </MudCard>
                }
            </MudItem>
        </MudGrid>
    }
</MudContainer>

@code {
    private List<Process>? _processes;
    private Guid _selectedProcessId;
    private DateTime _searchStart = DateTime.Now;
    private DateTime _searchEnd = DateTime.Now.AddDays(3);
    private DateTime? _searchStartDate;
    private DateTime? _searchEndDate;
    private int _granularityMinutes = 30;
    private List<RecommendationWindow>? _recommendations;
    private RiskAssessment? _nowAssessment;

    protected override async Task OnInitializedAsync()
    {
        _searchStartDate = _searchStart.Date;
        _searchEndDate = _searchEnd.Date;
        var client = CreateClient();
        _processes = await client.GetFromJsonAsync<List<Process>>("api/processes");
    }

    private async Task FindRecommendations()
    {
        if (_selectedProcessId == Guid.Empty) return;

        _recommendations = null;
        _nowAssessment = null;

        var start = _searchStartDate ?? _searchStart;
        var end = _searchEndDate ?? _searchEnd;

        var client = CreateClient();
        var url = $"api/recommendations?processId={_selectedProcessId}" +
                  $"&searchStart={Uri.EscapeDataString(start.ToString("O"))}" +
                  $"&searchEnd={Uri.EscapeDataString(end.ToString("O"))}" +
                  $"&granularityMinutes={_granularityMinutes}";

        var response = await client.GetAsync(url);
        if (response.IsSuccessStatusCode)
        {
            _recommendations = await response.Content.ReadFromJsonAsync<List<RecommendationWindow>>();
        }
        else
        {
            Snackbar.Add("Error al buscar recomendaciones", Severity.Error);
        }
    }

    private async Task SimulateNow()
    {
        if (_selectedProcessId == Guid.Empty) return;

        _recommendations = null;
        var client = CreateClient();
        var response = await client.GetAsync($"api/risk?processId={_selectedProcessId}");
        if (response.IsSuccessStatusCode)
        {
            _nowAssessment = await response.Content.ReadFromJsonAsync<RiskAssessment>();
        }
        else
        {
            Snackbar.Add("Error al simular ejecución actual", Severity.Error);
        }
    }

    private static Color GetRiskColor(RiskLevel level) => level switch
    {
        RiskLevel.None => Color.Success,
        RiskLevel.Low => Color.Info,
        RiskLevel.Medium => Color.Warning,
        RiskLevel.High => Color.Error,
        RiskLevel.Critical => Color.Dark,
        _ => Color.Default
    };

    private static Severity GetAlertSeverity(RiskLevel level) => level switch
    {
        RiskLevel.None => Severity.Success,
        RiskLevel.Low => Severity.Info,
        RiskLevel.Medium => Severity.Warning,
        RiskLevel.High or RiskLevel.Critical => Severity.Error,
        _ => Severity.Normal
    };

    private HttpClient CreateClient()
    {
        var client = HttpClientFactory.CreateClient();
        client.BaseAddress = new Uri(Navigation.BaseUri);
        return client;
    }
}
