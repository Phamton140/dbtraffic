@page "/"

<PageTitle>DbTraffic - Dashboard</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-6">
    <MudText Typo="Typo.h4" Class="mb-1">Dashboard</MudText>
    <MudText Typo="Typo.body2" Class="mb-4">Controlador de tráfico para cargas de trabajo SQL Server.</MudText>

    <MudGrid Spacing="2">
        <MudItem xs="12" sm="6" md="4">
            <MudCard Elevation="2" Style="height: 160px; position: relative; overflow: hidden;" Class="d-flex flex-column">
                <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Primary" Style="position: absolute; right: -8px; top: -8px; font-size: 120px; opacity: 0.10; z-index: 0;" />
                <MudCardContent Class="pa-3" Style="position: relative; z-index: 1;">
                    <MudText Typo="Typo.subtitle1" Style="font-weight: 500;">Riesgo</MudText>
                    <MudText Typo="Typo.caption">Simula ejecuciones y detecta conflictos.</MudText>
                </MudCardContent>
                <MudCardActions Class="mt-auto pt-0 px-3 pb-3" Style="position: relative; z-index: 1;">
                    <MudButton Href="risk" Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" FullWidth="true">Ir</MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>
        <MudItem xs="12" sm="6" md="4">
            <MudCard Elevation="2" Style="height: 160px; position: relative; overflow: hidden;" Class="d-flex flex-column">
                <MudIcon Icon="@Icons.Material.Filled.CalendarMonth" Color="Color.Secondary" Style="position: absolute; right: -8px; top: -8px; font-size: 120px; opacity: 0.10; z-index: 0;" />
                <MudCardContent Class="pa-3" Style="position: relative; z-index: 1;">
                    <MudText Typo="Typo.subtitle1" Style="font-weight: 500;">Recomendaciones</MudText>
                    <MudText Typo="Typo.caption">Busca ventanas de bajo riesgo.</MudText>
                </MudCardContent>
                <MudCardActions Class="mt-auto pt-0 px-3 pb-3" Style="position: relative; z-index: 1;">
                    <MudButton Href="recommendations" Variant="Variant.Filled" Color="Color.Secondary" Size="Size.Small" FullWidth="true">Buscar</MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>
        <MudItem xs="12" sm="6" md="4">
            <MudCard Elevation="2" Style="height: 160px; position: relative; overflow: hidden;" Class="d-flex flex-column">
                <MudIcon Icon="@Icons.Material.Filled.TrendingUp" Color="Color.Success" Style="position: absolute; right: -8px; top: -8px; font-size: 120px; opacity: 0.10; z-index: 0;" />
                <MudCardContent Class="pa-3" Style="position: relative; z-index: 1;">
                    <MudText Typo="Typo.subtitle1" Style="font-weight: 500;">Monitoreo</MudText>
                    <MudText Typo="Typo.caption">Métricas en tiempo real.</MudText>
                </MudCardContent>
                <MudCardActions Class="mt-auto pt-0 px-3 pb-3" Style="position: relative; z-index: 1;">
                    <MudButton Href="monitoring" Variant="Variant.Filled" Color="Color.Success" Size="Size.Small" FullWidth="true">Ver</MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>
        <MudItem xs="12" sm="6" md="4">
            <MudCard Elevation="2" Style="height: 160px; position: relative; overflow: hidden;" Class="d-flex flex-column">
                <MudIcon Icon="@Icons.Material.Filled.Storage" Color="Color.Info" Style="position: absolute; right: -8px; top: -8px; font-size: 120px; opacity: 0.10; z-index: 0;" />
                <MudCardContent Class="pa-3" Style="position: relative; z-index: 1;">
                    <MudText Typo="Typo.subtitle1" Style="font-weight: 500;">Instancias</MudText>
                    <MudText Typo="Typo.caption">Gestiona instancias SQL Server.</MudText>
                </MudCardContent>
                <MudCardActions Class="mt-auto pt-0 px-3 pb-3" Style="position: relative; z-index: 1;">
                    <MudButton Href="instances" Variant="Variant.Outlined" Color="Color.Info" Size="Size.Small" FullWidth="true">Gestionar</MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>
        <MudItem xs="12" sm="6" md="4">
            <MudCard Elevation="2" Style="height: 160px; position: relative; overflow: hidden;" Class="d-flex flex-column">
                <MudIcon Icon="@Icons.Material.Filled.Repeat" Color="Color.Info" Style="position: absolute; right: -8px; top: -8px; font-size: 120px; opacity: 0.10; z-index: 0;" />
                <MudCardContent Class="pa-3" Style="position: relative; z-index: 1;">
                    <MudText Typo="Typo.subtitle1" Style="font-weight: 500;">Procesos</MudText>
                    <MudText Typo="Typo.caption">Cataloga jobs y ETLs.</MudText>
                </MudCardContent>
                <MudCardActions Class="mt-auto pt-0 px-3 pb-3" Style="position: relative; z-index: 1;">
                    <MudButton Href="processes" Variant="Variant.Outlined" Color="Color.Info" Size="Size.Small" FullWidth="true">Gestionar</MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>
        <MudItem xs="12" sm="6" md="4">
            <MudCard Elevation="2" Style="height: 160px; position: relative; overflow: hidden;" Class="d-flex flex-column">
                <MudIcon Icon="@Icons.Material.Filled.Search" Color="Color.Info" Style="position: absolute; right: -8px; top: -8px; font-size: 120px; opacity: 0.10; z-index: 0;" />
                <MudCardContent Class="pa-3" Style="position: relative; z-index: 1;">
                    <MudText Typo="Typo.subtitle1" Style="font-weight: 500;">Descubrimiento</MudText>
                    <MudText Typo="Typo.caption">Descubre jobs y objetos.</MudText>
                </MudCardContent>
                <MudCardActions Class="mt-auto pt-0 px-3 pb-3" Style="position: relative; z-index: 1;">
                    <MudButton Href="discovery" Variant="Variant.Outlined" Color="Color.Info" Size="Size.Small" FullWidth="true">Descubrir</MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>
    </MudGrid>
</MudContainer>
