@page "/discovery"
@using DbTraffic.Core.Entities
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>Descubrimiento - DbTraffic</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-6">
    <MudText Typo="Typo.h4" Class="mb-4">Descubrimiento asistido</MudText>

    @if (_instances == null)
    {
        <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
    }
    else
    {
        <MudCard Elevation="2" Class="mb-4">
            <MudCardContent>
                <MudGrid>
                    <MudItem xs="12" md="6">
                        <MudSelect @bind-Value="_selectedInstanceId" Label="Instancia" Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true">
                            <MudSelectItem Value="Guid.Empty">Seleccione una instancia...</MudSelectItem>
                            @foreach (var instance in _instances)
                            {
                                <MudSelectItem Value="instance.Id">@instance.Name</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="6" Class="d-flex align-center">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="RunDiscovery" Disabled="@(_selectedInstanceId == Guid.Empty)" StartIcon="@Icons.Material.Filled.PlayArrow">Ejecutar descubrimiento</MudButton>
                        <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="LoadDiscoveryResults" Disabled="@(_selectedInstanceId == Guid.Empty)" Class="ml-2" StartIcon="@Icons.Material.Filled.Refresh">Ver resultados</MudButton>
                    </MudItem>
                </MudGrid>
            </MudCardContent>
        </MudCard>

        @if (!string.IsNullOrEmpty(_message))
        {
            <MudAlert Severity="Severity.Info" Class="mb-4" Dense="true">@_message</MudAlert>
        }

        @if (_jobs != null || _objects != null)
        {
            <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" Style="background-color: #FFFFFF;">
                <MudTabPanel Text="Jobs descubiertos" Icon="@Icons.Material.Filled.Schedule">
                    @if (_jobs == null || _jobs.Count == 0)
                    {
                        <MudText Typo="Typo.body2">No se encontraron jobs.</MudText>
                    }
                    else
                    {
                        <MudTable Items="_jobs" Hover="true" Striped="true" Bordered="true" Breakpoint="Breakpoint.Sm">
                            <HeaderContent>
                                <MudTh>Nombre</MudTh>
                                <MudTh>Habilitado</MudTh>
                                <MudTh>Proceso asociado</MudTh>
                                <MudTh>Asociar</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="Nombre">@context.Name</MudTd>
                                <MudTd DataLabel="Habilitado">
                                    @if (context.Enabled)
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Success">Sí</MudChip>
                                    }
                                    else
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Default">No</MudChip>
                                    }
                                </MudTd>
                                <MudTd DataLabel="Proceso asociado">@GetAssociatedProcessName(context.AssociatedProcessId)</MudTd>
                                <MudTd DataLabel="Asociar">
                                    <MudSelect T="Guid?" Value="context.AssociatedProcessId" ValueChanged="v => AssociateJob(context.Id, v)" Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true">
                                        <MudSelectItem T="Guid?" Value="null">Sin asociar</MudSelectItem>
                                        @foreach (var process in _processes ?? new List<Process>())
                                        {
                                            <MudSelectItem T="Guid?" Value="process.Id">@process.Name</MudSelectItem>
                                        }
                                    </MudSelect>
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    }
                </MudTabPanel>
                <MudTabPanel Text="Objetos descubiertos" Icon="@Icons.Material.Filled.Dataset">
                    @if (_objects == null || _objects.Count == 0)
                    {
                        <MudText Typo="Typo.body2">No se encontraron objetos de usuario en la base de datos configurada.</MudText>
                    }
                    else
                    {
                        <MudTable Items="_objects" Hover="true" Striped="true" Bordered="true" Breakpoint="Breakpoint.Sm">
                            <HeaderContent>
                                <MudTh>Esquema</MudTh>
                                <MudTh>Objeto</MudTh>
                                <MudTh>Tipo</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="Esquema">@context.SchemaName</MudTd>
                                <MudTd DataLabel="Objeto">@context.ObjectName</MudTd>
                                <MudTd DataLabel="Tipo">@context.ObjectType</MudTd>
                            </RowTemplate>
                        </MudTable>
                    }
                </MudTabPanel>
            </MudTabs>
        }
    }
</MudContainer>

@code {
    private List<Instance>? _instances;
    private List<Process>? _processes;
    private List<DiscoveredJob>? _jobs;
    private List<DiscoveredObject>? _objects;
    private Guid _selectedInstanceId;
    private string? _message;

    protected override async Task OnInitializedAsync()
    {
        var client = CreateClient();
        _instances = await client.GetFromJsonAsync<List<Instance>>("api/instances");
        _processes = await client.GetFromJsonAsync<List<Process>>("api/processes");
    }

    private async Task RunDiscovery()
    {
        if (_selectedInstanceId == Guid.Empty) return;

        _message = "Ejecutando descubrimiento...";
        var client = CreateClient();
        var response = await client.PostAsync($"api/discovery/run/{_selectedInstanceId}", null);
        if (response.IsSuccessStatusCode)
        {
            _message = "Descubrimiento completado.";
            Snackbar.Add("Descubrimiento completado", Severity.Success);
            await LoadDiscoveryResults();
        }
        else
        {
            _message = $"Error en descubrimiento: {response.StatusCode}";
            Snackbar.Add(_message, Severity.Error);
        }
    }

    private async Task LoadDiscoveryResults()
    {
        if (_selectedInstanceId == Guid.Empty) return;

        _message = "Cargando resultados...";
        var client = CreateClient();
        _jobs = await client.GetFromJsonAsync<List<DiscoveredJob>>($"api/discovery/jobs/{_selectedInstanceId}");
        _objects = await client.GetFromJsonAsync<List<DiscoveredObject>>($"api/discovery/objects/{_selectedInstanceId}");
        _message = null;
    }

    private string GetAssociatedProcessName(Guid? processId)
    {
        if (!processId.HasValue) return "Sin asociar";
        return _processes?.FirstOrDefault(p => p.Id == processId.Value)?.Name ?? "Desconocido";
    }

    private async Task AssociateJob(Guid jobId, Guid? processId)
    {
        var client = CreateClient();
        var response = await client.PostAsJsonAsync($"api/discovery/associate/{jobId}", new { ProcessId = processId });
        if (response.IsSuccessStatusCode)
        {
            await LoadDiscoveryResults();
            Snackbar.Add("Asociación actualizada", Severity.Success);
        }
        else
        {
            Snackbar.Add("Error al asociar job", Severity.Error);
        }
    }

    private HttpClient CreateClient()
    {
        var client = HttpClientFactory.CreateClient();
        client.BaseAddress = new Uri(Navigation.BaseUri);
        return client;
    }
}
