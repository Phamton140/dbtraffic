@page "/instances"
@using DbTraffic.Core.Entities
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>Instancias - DbTraffic</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-6">
    <MudText Typo="Typo.h4" Class="mb-4">Instancias SQL Server</MudText>

    @if (_instances == null)
    {
        <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
    }
    else
    {
        <MudGrid>
            <MudItem xs="12" lg="8">
                <MudTable Items="_instances" Hover="true" Striped="true" Bordered="true" Elevation="2" Breakpoint="Breakpoint.Sm" Dense="true" Class="compact-table">
                    <HeaderContent>
                        <MudTh>Nombre</MudTh>
                        <MudTh>Descripción</MudTh>
                        <MudTh>Estado</MudTh>
                        <MudTh Style="text-align: right;">Acciones</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Nombre">@context.Name</MudTd>
                        <MudTd DataLabel="Descripción">@context.Description</MudTd>
                        <MudTd DataLabel="Estado">
                            @if (context.IsActive)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Success" Class="status-chip">Activa</MudChip>
                            }
                            else
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Default" Class="status-chip">Inactiva</MudChip>
                            }
                        </MudTd>
                        <MudTd Style="text-align: right;">
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="() => DeleteInstance(context.Id)" aria-label="Eliminar instancia" />
                        </MudTd>
                    </RowTemplate>
                    <NoRecordsContent>
                        <MudText Typo="Typo.body2">No hay instancias registradas.</MudText>
                    </NoRecordsContent>
                </MudTable>
            </MudItem>

            <MudItem xs="12" lg="4">
                <MudCard Elevation="2">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">Nueva instancia</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudTextField @bind-Value="_newInstance.Name" Label="Nombre" Variant="Variant.Outlined" Margin="Margin.Dense" Required="true" />
                        <MudTextField @bind-Value="_newInstance.ConnectionString" Label="Cadena de conexión" Variant="Variant.Outlined" Margin="Margin.Dense" Required="true" Class="mt-3" />
                        <MudTextField @bind-Value="_newInstance.Description" Label="Descripción" Variant="Variant.Outlined" Margin="Margin.Dense" Lines="3" Class="mt-3" />
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="CreateInstance">Crear</MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>
        </MudGrid>
    }
</MudContainer>

@code {
    private List<Instance>? _instances;
    private Instance _newInstance = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadInstancesAsync();
    }

    private async Task LoadInstancesAsync()
    {
        var client = CreateClient();
        _instances = await client.GetFromJsonAsync<List<Instance>>("api/instances");
    }

    private async Task CreateInstance()
    {
        var client = CreateClient();
        var response = await client.PostAsJsonAsync("api/instances", _newInstance);
        if (response.IsSuccessStatusCode)
        {
            _newInstance = new Instance();
            await LoadInstancesAsync();
            Snackbar.Add("Instancia creada", Severity.Success);
        }
        else
        {
            var detail = await response.Content.ReadAsStringAsync();
            Snackbar.Add($"Error al crear instancia: {detail}", Severity.Error);
        }
    }

    private async Task DeleteInstance(Guid id)
    {
        var client = CreateClient();
        var response = await client.DeleteAsync($"api/instances/{id}");
        if (response.IsSuccessStatusCode)
        {
            await LoadInstancesAsync();
            Snackbar.Add("Instancia eliminada", Severity.Success);
        }
        else
        {
            Snackbar.Add($"Error al eliminar instancia: {response.StatusCode}", Severity.Error);
        }
    }

    private HttpClient CreateClient()
    {
        var client = HttpClientFactory.CreateClient();
        client.BaseAddress = new Uri(Navigation.BaseUri);
        return client;
    }
}
